# ═══════════════════════════════════════════════════
# Configuration — service-alertes (Express)
# ═══════════════════════════════════════════════════

# Serveur
PORT=3002

# ── Base de données PostgreSQL ────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_NAME=alertes_db
DATABASE_USER=sgfv
DATABASE_PASSWORD=sgfv_secret
DATABASE_URL=postgresql://sgfv:sgfv_secret@localhost:5435/alertes_db

# ── Kafka ─────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=service-alertes-group

# Topics consommés (ce service écoute TOUS les topics)
KAFKA_TOPIC_VEHICULES=vehicules
KAFKA_TOPIC_CONDUCTEURS=conducteurs
KAFKA_TOPIC_MAINTENANCE=maintenance
KAFKA_TOPIC_LOCATIONS=locations
KAFKA_TOPIC_UTILISATEURS=utilisateurs

# Règle métier : alerte URGENCE non lue après 1h → réémiise
ALERTE_URGENCE_REEMISSION_MS=3600000

# ── Keycloak — validation JWT ─────────────────────
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=sgfv

# ── OpenTelemetry ─────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=service-alertes