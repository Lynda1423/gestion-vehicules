# ═══════════════════════════════════════════════════
# Configuration — service-localisation (Express)
# ═══════════════════════════════════════════════════

# Serveur REST
PORT=8084

# Port gRPC / WebSocket temps réel
GRPC_PORT=3001

# ── Base de données TimescaleDB ───────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5436
DATABASE_NAME=localisation_db
DATABASE_USER=sgfv
DATABASE_PASSWORD=sgfv_secret
DATABASE_URL=postgresql://sgfv:sgfv_secret@localhost:5436/localisation_db

# ── Kafka ─────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=service-localisation-group

# Topics produits (AsyncAPI topic-locations.yaml)
KAFKA_TOPIC_LOCATIONS=locations
KAFKA_TOPIC_VEHICULES=vehicules

# ── Keycloak — validation JWT ─────────────────────
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=sgfv

# ── OpenTelemetry ─────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=service-localisation

# ── Règles métier ─────────────────────────────────
GPS_RECORD_INTERVAL_SECONDS=10
VITESSE_EXCESSIVE_SEUIL=130